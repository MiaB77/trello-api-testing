      "name": "Boards",
      "item": [
        {
          "name": "Create a Board",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.collectionVariables.set(\"boardId\", response.id);",
                  "",
                  "pm.test(\"Board is created\", () => {",
                  "    pm.expect(response.name).to.eql(\"Learning Postman \" + pm.collectionVariables.get(\"boardNumber\"));",
                  "    pm.expect(response.closed).to.eql(false);",
                  "",
                  "    console.log(response.name);",
                  "    console.log(response.closed);",
                  "});",
                  "",
                  "pm.test(\"Board is private\", () => {",
                  "    pm.expect(response.prefs.permissionLevel).to.eql(\"private\");",
                  "    console.log(response.prefs.permissionLevel);",
                  "});",
                  "",
                  "pm.test(\"Calendar is disabled\", () => {",
                  "    const calendarView = response.prefs.switcherViews.find(view => view.viewType === \"Calendar\");",
                  "    pm.expect(calendarView).to.an(\"object\");",
                  "    pm.expect(calendarView.enabled).to.be.false;",
                  "});",
                  "",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// 1. Citește variabila din colecție și stocheaz-o într-o variabilă JS\r",
                  "let boardNumber = pm.collectionVariables.get(\"boardNumber\");\r",
                  "if (isNaN(boardNumber)) {\r",
                  "    boardNumber = 0; // Dacă variabila nu există sau nu este un număr, o inițializează cu 1. isNaN = is not a number\r",
                  "}\r",
                  "// 2. Incrementează variabila JS\r",
                  "boardNumber++;\r",
                  "\r",
                  "// 3. Actualizează variabila din colecție cu noua valoare\r",
                  "pm.collectionVariables.set(\"boardNumber\", boardNumber);\r",
                  "\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/1/boards/?key={{trelloKey}}&token={{trelloToken}}&name=Learning Postman {{boardNumber}}",
              "host": [
